FROM node:20-alpine
WORKDIR /app
COPY package*.json ./
RUN npm install --production
COPY . .
RUN mkdir -p public
RUN node -e "const fs=require('fs');const html=Buffer.from('','base64').toString();fs.writeFileSync('./public/index.html',html);console.log('HTML created');"
EXPOSE 3000
CMD ["node", "src/server.js"]
