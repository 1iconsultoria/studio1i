FROM node:20-alpine
WORKDIR /app
COPY package*.json ./
RUN npm install --production
COPY . .
RUN mkdir -p public
RUN node -e "const fs=require('fs');fs.writeFileSync('./public/index.html',Buffer.from('','base64').toString());console.log('HTML ok '+fs.statSync('./public/index.html').size+' bytes');"
EXPOSE 3000
CMD ["node", "src/server.js"]
